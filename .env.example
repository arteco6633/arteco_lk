# Supabase (публичные — можно в Vercel)
NEXT_PUBLIC_SUPABASE_URL=https://zfotbrmjqqlodqryznpp.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Prisma → PostgreSQL Supabase
# Dashboard → Project Settings → Database → Connection string
#
# DATABASE_URL — Transaction pooler (порт 6543), для приложения:
# postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
#
# DIRECT_URL — Direct / Session (порт 5432), для миграций:
# postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
DATABASE_URL=
DIRECT_URL=

# Секрет для cookie-сессий
SESSION_SECRET=change-me-in-production
