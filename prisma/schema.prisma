generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  MANAGER
  CONTRACTOR
  SORTER
  DRILLER
  QC
  PACKER
}

enum PartStatus {
  CREATED
  RECEIVED
  SORTED
  DRILLED
  QC_PASSED
  QC_FAILED
  PACKED
}

enum DocumentType {
  ASSEMBLY_DRAWING
  PART_DETAIL
  LABEL
}

enum OrderStatus {
  NEW
  PROCUREMENT
  PRODUCTION
  COMPLETED
  CANCELLED
}

enum StorageProvider {
  LOCAL
  SUPABASE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
}

model Order {
  id        String       @id @default(cuid())
  number    String       @unique
  title     String?
  notes     String?
  status    OrderStatus  @default(NEW)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  products  Product[]
  documents Document[]
}

model Product {
  id       String         @id @default(cuid())
  orderId  String
  order    Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  number   String
  name     String
  parts    Part[]
  documents Document[]
  hardware HardwareItem[]

  @@unique([orderId, number])
}

model Part {
  id             String      @id @default(cuid())
  productId      String
  product        Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  specNumber     Int?
  name           String
  code           String?
  module         String?
  length         String?
  width          String?
  dimensions     String?
  quantity       Int         @default(1)
  material       String?
  sectionOrder   Int?
  edging         String?
  groove         String?
  rectangular    String?
  status         PartStatus  @default(CREATED)
  drillPhotoPath String?
  qcComment      String?
  receivedAt     DateTime?
  sortedAt       DateTime?
  drilledAt      DateTime?
  qcAt           DateTime?
  packedAt       DateTime?
  history        PartHistory[]
}

model HardwareItem {
  id         String  @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  specNumber Int?
  code       String?
  name       String
  quantity   Int     @default(1)
  unit       String?
  purchased  Boolean   @default(false)
  purchasedAt DateTime?
  packed     Boolean @default(false)
}

model Document {
  id              String          @id @default(cuid())
  orderId         String?
  productId       String?
  order           Order?          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product?        @relation(fields: [productId], references: [id], onDelete: Cascade)
  type            DocumentType
  filename        String
  filepath        String
  storageProvider StorageProvider @default(LOCAL)
  uploadedAt      DateTime        @default(now())

  @@index([orderId])
  @@index([productId])
}

model PartHistory {
  id         String      @id @default(cuid())
  partId     String
  part       Part        @relation(fields: [partId], references: [id], onDelete: Cascade)
  userId     String
  userName   String
  action     String
  fromStatus PartStatus?
  toStatus   PartStatus?
  comment    String?
  createdAt  DateTime    @default(now())
}

enum CatalogItemType {
  BOARD
  HARDWARE
  EDGE
  SERVICE
  OTHER
}

enum CatalogPriceUnit {
  SHEET
  SQM
  PIECE
  METER
  KG
  OTHER
}

model CatalogCategory {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  type      CatalogItemType @default(BOARD)
  sortOrder Int             @default(0)
  items     CatalogItem[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([type])
}

model CatalogItem {
  id            String           @id @default(cuid())
  categoryId    String
  category      CatalogCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subcategory   String?
  name          String
  code          String?
  type          CatalogItemType
  unit          CatalogPriceUnit @default(SQM)
  platePrice    Float?
  heightM       Float?
  widthM        Float?
  sheetAreaSqm  Float?
  costPrice     Float?
  clientPrice   Float?
  link          String?
  notes         String?
  active        Boolean          @default(true)
  sourceSheet   String?
  sourceRow     Int?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([categoryId])
  @@index([name])
  @@index([type])
  @@index([subcategory])
}

model CatalogImport {
  id           String   @id @default(cuid())
  filename     String
  sheetCount   Int      @default(0)
  itemCount    Int      @default(0)
  createdCount Int      @default(0)
  updatedCount Int      @default(0)
  skippedCount Int      @default(0)
  errors       String?
  importedBy   String
  createdAt    DateTime @default(now())
}
