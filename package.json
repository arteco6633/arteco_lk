{
  "name": "mebel-flow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "predev": "prisma generate",
    "build": "prisma generate && prisma migrate deploy && next build --webpack",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma migrate dev && tsx prisma/seed.ts && tsx prisma/migrate-document-types.ts",
    "template:excel": "tsx scripts/generate-template.ts",
    "test:excel": "tsx scripts/test-excel-import.ts",
    "test:pdf": "tsx scripts/test-pdf-parser.ts"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.1",
    "@prisma/client": "^6.19.3",
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^3.0.3",
    "next": "16.2.9",
    "pdfjs-dist": "^6.0.227",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
